{
  "profile_id": "acme-harness-v1",
  "stages": [
    {
      "stage_id": "plan",
      "role": "planner",
      "skill": "echo",
      "artifact_name": "plan.json",
      "commit_message": "planner: add plan.json",
      "on_pass": "security_review",
      "on_fail": "blocked"
    },
    {
      "stage_id": "security_review",
      "role": "security_reviewer",
      "skill": "security-reviewer",
      "artifact_name": "security_review.md",
      "commit_message": "security-reviewer: add security_review.md",
      "on_pass": "implementation",
      "on_fail": "blocked"
    },
    {
      "stage_id": "implementation",
      "role": "implementer",
      "skill": "scout",
      "artifact_name": "implementation.md",
      "commit_message": "implementer: add implementation.md",
      "on_pass": "github_issue_sync",
      "on_fail": "retry"
    },
    {
      "stage_id": "github_issue_sync",
      "role": "issue_opener",
      "skill": "github-issue-opener",
      "artifact_name": "issue_sync.md",
      "commit_message": "issue-opener: add issue_sync.md",
      "on_pass": "slack_notify",
      "on_fail": "retry"
    },
    {
      "stage_id": "slack_notify",
      "role": "communicator_slack",
      "skill": "slack-notifier",
      "artifact_name": "slack_notification.md",
      "commit_message": "slack-notifier: add slack_notification.md",
      "on_pass": "verify",
      "on_fail": "verify"
    },
    {
      "stage_id": "verify",
      "role": "quality_gate",
      "skill": "warden",
      "artifact_name": "validation.md",
      "commit_message": "warden: add validation.md",
      "gate": true,
      "on_pass": "done",
      "on_fail": "retry"
    }
  ]
}
