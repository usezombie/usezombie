{
  "default_temperature": 0.2,

  "models": {
    "providers": {
      "openrouter": {
        "api_key": "${NULLCLAW_API_KEY}"
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4"
      }
    }
  },

  "autonomy": {
    "level": "full",
    "workspace_only": true,
    "max_actions_per_hour": 200
  },

  "security": {
    "sandbox": {
      "backend": "auto"
    }
  },

  "agent": {
    "max_tool_iterations": 50,
    "max_history_messages": 100,
    "message_timeout_secs": 600
  },

  "memory": {
    "backend": "memory",
    "auto_save": false
  }
}
