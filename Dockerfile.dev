FROM alpine:3.21

RUN apk add --no-cache curl xz git bubblewrap

RUN curl -L https://ziglang.org/download/0.15.2/zig-linux-x86_64-0.15.2.tar.xz | tar xJ -C /usr/local
ENV PATH="/usr/local/zig-linux-x86_64-0.15.2:${PATH}"

WORKDIR /app

ENV PORT=3000
EXPOSE 3000

CMD ["zig", "build", "run", "--", "serve"]
