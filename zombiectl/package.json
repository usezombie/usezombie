{
  "name": "@usezombie/zombiectl",
  "version": "0.37.0",
  "description": "usezombie CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/usezombie/usezombie"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "zombiectl": "./dist/bin/zombiectl.js"
  },
  "files": [
    "dist",
    "samples",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "test": "npm run build && node ./scripts/enforce-coverage.mjs",
    "test:coverage": "npm run build && bun test --coverage",
    "test:acceptance": "npm run build && bun test test/acceptance",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test scripts && node ./scripts/audit-runtime-imports.mjs && node ./scripts/audit-const-names.mjs && tsc --noEmit",
    "lint:fix": "oxlint src test scripts --fix && node ./scripts/audit-runtime-imports.mjs && node ./scripts/audit-const-names.mjs && tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build && node ./scripts/prepublish.mjs",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "dependencies": {
    "@vercel/detect-agent": "^1.2.3",
    "commander": "^14.0.3",
    "effect": "4.0.0-beta.67",
    "posthog-node": "^5.34.1",
    "uuid": "^14.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.13",
    "oxlint": "^1.64.0",
    "playwright": "^1.60.0",
    "typescript": "6.0.3"
  }
}
