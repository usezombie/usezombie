{
  "name": "@usezombie/zombiectl",
  "version": "0.34.0",
  "description": "usezombie CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/usezombie/usezombie"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "zombiectl": "./bin/zombiectl.js"
  },
  "files": [
    "bin",
    "src",
    "samples",
    "skills",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "test": "node ./scripts/run-tests.mjs",
    "test:coverage": "bun test --coverage",
    "test:acceptance": "node ./scripts/run-acceptance.mjs",
    "lint": "oxlint src bin test scripts && node ./scripts/audit-runtime-imports.mjs",
    "lint:fix": "oxlint src bin test scripts --fix && node ./scripts/audit-runtime-imports.mjs",
    "build": "node --check ./src/cli.js && node --check ./bin/zombiectl.js",
    "prepublishOnly": "node ./scripts/prepublish.mjs",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "posthog-node": "^5.33.4",
    "uuid": "^11.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "oxlint": "^1.63.0",
    "playwright": "^1.49.0"
  }
}
