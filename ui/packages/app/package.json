{
  "name": "usezombie-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware .",
    "test": "vitest run tests/*.test.ts lib/*.test.ts lib/**/*.test.ts 'app/(dashboard)'",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:smoke": "bunx playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:acceptance": "bunx playwright test --config=playwright.acceptance.config.ts",
    "test:e2e:acceptance:local": "NEXT_PUBLIC_API_URL=http://localhost:3000 bunx playwright test --config=playwright.acceptance.config.ts",
    "test:e2e:acceptance:dev": "BASE_URL=https://usezombie-app.vercel.app NEXT_PUBLIC_API_URL=https://api-dev.usezombie.com bunx playwright test --config=playwright.acceptance.config.ts",
    "test:e2e:acceptance:prod": "BASE_URL=https://app.usezombie.com NEXT_PUBLIC_API_URL=https://api.usezombie.com bunx playwright test --config=playwright.acceptance.config.ts",
    "qa": "bun run test && bun run test:e2e",
    "test:coverage": "vitest run tests/*.test.ts lib/*.test.ts lib/**/*.test.ts 'app/(dashboard)' --coverage",
    "qa:smoke": "bun run test:smoke && bun run test:e2e:smoke"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.14",
    "@clerk/nextjs": "^7.4.3",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "1.1.12",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-tooltip": "1.2.9",
    "@usezombie/design-system": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cron-parser": "^5.5.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "posthog-js": "^1.382.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@clerk/testing": "^2.0.35",
    "@playwright/test": "1.60.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-istanbul": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "happy-dom": "20",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "size-limit": "^12.1.0",
    "svix": "^1.95.1",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
