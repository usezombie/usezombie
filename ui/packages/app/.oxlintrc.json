{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/refs/heads/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "react-perf", "jsx-a11y", "nextjs", "import"],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "settings": {
    "react": {
      "version": "19"
    },
    "next": {
      "rootDir": "."
    }
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "const-comparisons": "error",
    "no-cond-assign": "error",
    "no-const-assign": "error",
    "no-debugger": "error",
    "no-dupe-class-members": "error",
    "no-dupe-keys": "error",
    "no-empty-pattern": "error",
    "no-extra-boolean-cast": "error",
    "no-prototype-builtins": "error",
    "no-throw-literal": "error",
    "no-unexpected-multiline": "error",
    "no-unmodified-loop-condition": "error",
    "no-unsafe-finally": "error",
    "no-var": "error",
    "prefer-const": "error",
    "import/no-duplicates": "error",
    "import/no-self-import": "error",
    "jsx-a11y/alt-text": "error",
    "jsx-a11y/aria-props": "error",
    "jsx-a11y/aria-role": "error",
    "jsx-a11y/iframe-has-title": "error",
    "jsx-a11y/no-redundant-roles": "error",
    "jsx-a11y/role-has-required-aria-props": "error",
    "jsx-a11y/role-supports-aria-props": "error",
    "react/jsx-key": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/jsx-no-undef": "error",
    "react/no-danger-with-children": "error",
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "error",
    "react/void-dom-elements-no-children": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-misused-spread": "off",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/prefer-as-const": "error",
    "no-control-regex": "off",
    "no-useless-escape": "off",
    "no-this-alias": "off",
    "triple-slash-reference": "off",
    "no-new-array": "off",
    "no-thenable": "off",
    "typescript/no-confusing-non-null-assertion": "error",
    "typescript/no-non-null-asserted-nullish-coalescing": "error",
    "typescript/no-non-null-asserted-optional-chain": "error"
  },
  "ignorePatterns": [
    ".next/**",
    "node_modules/**",
    "coverage/**",
    "playwright-report/**",
    "playwright-results/**"
  ],
  "overrides": [
    {
      "files": ["tests/**", "**/*.test.ts", "**/*.test.tsx", "playwright.config.ts"],
      "rules": {
        "no-unused-vars": "off",
        "no-unused-private-class-members": "off",
        "no-unnecessary-await": "off",
        "no-throw-literal": "off",
        "typescript/no-non-null-assertion": "off"
      }
    }
  ]
}
