{
  "openapi": "3.1.0",
  "info": {
    "title": "UseZombie Control Plane API",
    "version": "1.0.0",
    "description": "Agent Delivery Control Plane — spec-to-PR automation via Echo → Scout → Warden pipeline."
  },
  "paths": {
    "/v1/runs": {
      "post": {
        "operationId": "start_run",
        "summary": "Start a spec-to-PR run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workspace_id", "spec_id", "mode", "requested_by", "idempotency_key"],
                "properties": {
                  "workspace_id": { "type": "string" },
                  "spec_id": { "type": "string" },
                  "mode": { "type": "string", "enum": ["web", "api"] },
                  "requested_by": { "type": "string" },
                  "idempotency_key": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Run queued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["run_id", "state", "attempt", "request_id"],
                  "properties": {
                    "run_id": { "type": "string" },
                    "state": { "type": "string", "example": "SPEC_QUEUED" },
                    "attempt": { "type": "integer" },
                    "request_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/runs/{run_id}": {
      "get": {
        "operationId": "get_run",
        "summary": "Get run status, transitions, artifacts, and policy events",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Run details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["run_id", "workspace_id", "spec_id", "current_state", "attempt", "mode", "requested_by", "branch", "created_at", "updated_at", "transitions", "artifacts", "policy_events", "request_id"],
                  "properties": {
                    "run_id": { "type": "string" },
                    "workspace_id": { "type": "string" },
                    "spec_id": { "type": "string" },
                    "current_state": { "type": "string" },
                    "attempt": { "type": "integer" },
                    "mode": { "type": "string", "enum": ["web", "api"] },
                    "requested_by": { "type": "string" },
                    "branch": { "type": "string" },
                    "pr_url": { "type": "string", "nullable": true },
                    "created_at": { "type": "integer", "description": "Unix ms" },
                    "updated_at": { "type": "integer", "description": "Unix ms" },
                    "transitions": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Transition" }
                    },
                    "artifacts": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Artifact" }
                    },
                    "policy_events": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/PolicyEvent" }
                    },
                    "request_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/runs/{run_id}:retry": {
      "post": {
        "operationId": "retry_run",
        "summary": "Retry a blocked or failed run",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason", "retry_token"],
                "properties": {
                  "reason": { "type": "string" },
                  "retry_token": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Retry queued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["run_id", "state", "attempt", "request_id"],
                  "properties": {
                    "run_id": { "type": "string" },
                    "state": { "type": "string", "example": "SPEC_QUEUED" },
                    "attempt": { "type": "integer" },
                    "request_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/workspaces/{workspace_id}:pause": {
      "post": {
        "operationId": "pause_workspace",
        "summary": "Pause or unpause a workspace",
        "parameters": [
          {
            "name": "workspace_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["pause", "reason", "version"],
                "properties": {
                  "pause": { "type": "boolean" },
                  "reason": { "type": "string" },
                  "version": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workspace pause state updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["workspace_id", "paused", "version", "request_id"],
                  "properties": {
                    "workspace_id": { "type": "string" },
                    "paused": { "type": "boolean" },
                    "version": { "type": "integer" },
                    "request_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/specs": {
      "get": {
        "operationId": "list_specs",
        "summary": "List specs for a workspace",
        "parameters": [
          { "name": "workspace_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "cursor", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Spec list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["specs", "total", "request_id"],
                  "properties": {
                    "specs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/SpecSummary" }
                    },
                    "total": { "type": "integer" },
                    "request_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/workspaces/{workspace_id}:sync": {
      "post": {
        "operationId": "sync_specs",
        "summary": "Sync specs from repo PENDING_*.md files to control plane",
        "parameters": [
          {
            "name": "workspace_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Sync complete",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["synced_count", "total_pending", "specs", "request_id"],
                  "properties": {
                    "synced_count": { "type": "integer" },
                    "total_pending": { "type": "integer" },
                    "specs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/SpecSummary" }
                    },
                    "request_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Transition": {
        "type": "object",
        "properties": {
          "state_from": { "type": "string" },
          "state_to": { "type": "string" },
          "actor": { "type": "string" },
          "reason_code": { "type": "string" },
          "ts": { "type": "integer", "description": "Unix ms" }
        }
      },
      "Artifact": {
        "type": "object",
        "properties": {
          "artifact_name": { "type": "string" },
          "object_key": { "type": "string", "description": "git path: docs/runs/<run_id>/<name>" },
          "checksum_sha256": { "type": "string" },
          "producer": { "type": "string", "enum": ["echo", "scout", "warden", "orchestrator"] },
          "attempt": { "type": "integer" },
          "created_at": { "type": "integer", "description": "Unix ms" }
        }
      },
      "PolicyEvent": {
        "type": "object",
        "properties": {
          "action_class": { "type": "string", "enum": ["safe", "sensitive", "critical"] },
          "decision": { "type": "string", "enum": ["allow", "deny", "require_confirmation"] },
          "rule_id": { "type": "string" },
          "actor": { "type": "string" },
          "ts": { "type": "integer", "description": "Unix ms" }
        }
      },
      "SpecSummary": {
        "type": "object",
        "properties": {
          "spec_id": { "type": "string" },
          "file_path": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "in_progress", "done", "failed"] },
          "created_at": { "type": "integer" },
          "updated_at": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error", "request_id"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": { "type": "object", "additionalProperties": true }
            }
          },
          "request_id": { "type": "string" }
        }
      }
    },
    "responses": {
      "Error": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}
