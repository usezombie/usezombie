{
  "name": "usezombie-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src tests/e2e playwright.config.ts",
    "lint:fix": "eslint src tests/e2e playwright.config.ts --fix",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --workers=1",
    "test:e2e:smoke": "playwright test --workers=1 tests/e2e/smoke.spec.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@usezombie/design-system": "workspace:*",
    "posthog-js": "1.360.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "4.2.1",
    "typescript": "6.0.1-rc",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
