{
  "name": "usezombie-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node ./scripts/prebuild.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src tests/e2e playwright.config.ts",
    "lint:fix": "eslint src tests/e2e playwright.config.ts --fix",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --workers=1",
    "test:e2e:smoke": "playwright test --workers=1 tests/e2e/smoke.spec.ts",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit"
  },
  "dependencies": {
    "@usezombie/design-system": "workspace:*",
    "posthog-js": "^1.372.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "^8.0.11",
    "vitest": "4.1.5"
  }
}
