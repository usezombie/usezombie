# Pinned versions + checksums for the CI Zig base images.
#
# Source of truth: https://ziglang.org/download/index.json (consulted once at
# pin time). The Dockerfiles fetch from pkg.machengine.org primarily because
# ziglang.org/download has had recurring CI hangs; the mirror is well
# maintained by the Mach team and the SHA256 is the trust anchor regardless of
# which mirror served the bytes.
#
# To bump the Zig version:
#   ./build_and_push.sh fetch-shas <new-version>
# This rewrites the four ZIG_SHA256_* lines below.

ZIG_VERSION=0.15.2

ZIG_SHA256_X86_64_LINUX=02aa270f183da276e5b5920b1dac44a63f1a49e55050ebde3aecc9eb82f93239
ZIG_SHA256_AARCH64_LINUX=958ed7d1e00d0ea76590d27666efbf7a932281b3d7ba0c6b01b0ff26498f667f

# macOS hashes are tracked here for completeness but are unused by the CI
# images (macOS lanes use mlugg/setup-zig directly — Apple does not allow
# macOS in containers, and the Linux-CDN hangs that motivated this work do
# not affect the macOS download path).
ZIG_SHA256_X86_64_MACOS=375b6909fc1495d16fc2c7db9538f707456bfc3373b14ee83fdd3e22b3d43f7f
ZIG_SHA256_AARCH64_MACOS=3cc2bab367e185cdfb27501c4b30b1b0653c28d9f73df8dc91488e66ece5fa6b
